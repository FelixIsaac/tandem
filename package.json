{
  "name": "@felixisaac/tandem",
  "version": "1.1.0",
  "description": "Browser automation for AI agents via Chrome extension + Native Messaging. Works with OpenCode, Claude Code, and any MCP-compatible agent.",
  "type": "module",
  "bin": {
    "tandem": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "extension/",
    ".opencode/",
    "AGENTS.md",
    "CLAUDE.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "install-extension": "node bin/cli.js install",
    "prepublishOnly": "node --check src/server.js && node --check src/host.js && node --check bin/cli.js",
    "gen-icons": "node scripts/gen-icons.mjs"
  },
  "devDependencies": {
    "@google/genai": "^1.50.1",
    "sharp": "^0.33.5"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "browser",
    "automation",
    "chrome",
    "ai",
    "llm",
    "claude",
    "opencode",
    "agent"
  ],
  "author": "Felix Lim <limfelix16@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixisaac/tandem.git"
  },
  "bugs": {
    "url": "https://github.com/felixisaac/tandem/issues"
  },
  "homepage": "https://github.com/felixisaac/tandem#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0"
  }
}
