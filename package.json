{
  "name": "@felixisaac/opencode-browser",
  "version": "1.0.0",
  "description": "Browser automation for AI agents via Chrome extension + Native Messaging. Works with OpenCode, Claude Code, and any MCP-compatible agent.",
  "type": "module",
  "bin": {
    "opencode-browser": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "extension/",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "install-extension": "node bin/cli.js install"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser",
    "automation",
    "chrome",
    "ai",
    "llm",
    "claude",
    "opencode",
    "agent"
  ],
