  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixisaac/opencode-browser.git"
  },
  "bugs": {
    "url": "https://github.com/felixisaac/opencode-browser/issues"
  },
  "homepage": "https://github.com/felixisaac/opencode-browser#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0"
  }
}
